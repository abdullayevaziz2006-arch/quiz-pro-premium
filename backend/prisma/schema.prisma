generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id        String     @id // Firebase UID
  email     String?
  questions Question[]
  sessions  Session[]
  results   Result[]
  criteria  Criteria[]
  settings  Settings?
  createdAt DateTime   @default(now())
}

model Question {
  id            String   @id @default(cuid())
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  uid           String?
  text          String
  options       String   // JSON stringified array
  correctAnswer String
  subjectId     String?  // Fan ID si
  subject       String?
  level         String?
  createdAt     DateTime @default(now())
}

model Session {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name        String
  isActive    Boolean  @default(true)
  questionIds String   @default("[]")
  createdAt   DateTime @default(now())
  results     Result[]
}

model Result {
  id        String   @id @default(cuid())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])
  student   String   // JSON stringified object
  score     Int
  total     Int
  answers   String   // JSON stringified array
  date      DateTime @default(now())
}

model Criteria {
  id        Int     @id @default(autoincrement())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  grade     Int
  min       Int
}

model Settings {
  id               Int     @id @default(autoincrement())
  teacherId        String  @unique
  teacher          Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questionsPerTest Int     @default(20)
  timePerQuestion  Int     @default(120)
  teacherName      String  @default("")
  groups           String  @default("[]") // JSON stringified groups array
}
